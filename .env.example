# Clerk (https://clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Webhook signing secret (Clerk Dashboard → Webhooks → endpoint /api/webhooks/clerk)
CLERK_WEBHOOK_SECRET=
# App origin for invite redirect URLs (defaults to http://localhost:3000 in dev)
NEXT_PUBLIC_APP_URL=
# Optional Clerk path overrides (defaults match /sign-in, /sign-up, /after-sign-in)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/after-sign-in
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/after-sign-in

# Supabase (https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated Supabase project URLs allowed for npm run seed:materials
ALLOWED_SEED_HOSTS=https://your-dev-project.supabase.co

# Resend (https://resend.com) — required for contact form email delivery
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Inbox for /contact submissions (defaults to sales@mwfab.co)
CONTACT_TO_EMAIL=

# QuickBooks Online (https://developer.intuit.com) — phase-1 integration
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:3000/api/qbo/callback
QBO_ENVIRONMENT=sandbox
# openssl rand -base64 32
QBO_TOKEN_ENCRYPTION_KEY=
QBO_DEFAULT_ITEM_ID=
# US estimate lines: TAX (taxable) or NON (non-taxable) — not the numeric Id from TaxCode query
QBO_LINE_TAX_CODE=TAX
